'use client'
import { useState } from 'react';
import { supabase } from '../../lib/supabase';

export default function SellerAuth() {
  const [mode, setMode] = useState('signup');
  const [email, setEmail] = useState('');
  const [password, setPassword] = useState('');
  const [confirmPassword, setConfirmPassword] = useState('');
  const [showPassword, setShowPassword] = useState(false);
  const [storeName, setStoreName] = useState('');
  const [ecocashNumber, setEcocashNumber] = useState('');
  const [city, setCity] = useState('Bulawayo');
  const [otp, setOtp] = useState('');
  const [awaitingOtp, setAwaitingOtp] = useState(false);
  const [loading, setLoading] = useState(false);
  const [message, setMessage] = useState('');

  const handleSignUp = async () => {
    if (!email || !password || !confirmPassword || !storeName || !ecocashNumber) {
      setMessage('Fill all fields');
      return;
    }
    if (password.length < 6) {
      setMessage('Password must be at least 6 characters');
      return;
    }
    if (password !== confirmPassword) {
      setMessage('Passwords do not match');
      return;
    }
    setLoading(true);
    setMessage('');

    const { error } = await supabase.auth.signUp({
      email: email,
      password: password,
      options: {
        data: {
          role: 'seller',
          store_name: storeName,
          ecocash_number: ecocashNumber,
          city: city
        }
      }
    });

    if (error) {
      setMessage('Error: ' + error.message);
    } else {
      setMessage('Check your email for 6-digit verification code');
      setAwaitingOtp(true);
    }
    setLoading(false);
  };

  const handleVerifyOtp = async () => {
    setLoading(true);
    const { error } = await supabase.auth.verifyOtp({
      email: email,
      token: otp,
      type: 'signup'
    });
    
    if (error) {
      setMessage('Error: ' + error.message);
    } else {
      setMessage('Account verified! Redirecting...');
      setTimeout(() => window.location.href = '/seller/dashboard', 1000);
    }
    setLoading(false);
  };

  const handleSignIn = async () => {
    if (!email || !password) {
      setMessage('Enter email and password');
      return;
    }
    setLoading(true);
    setMessage('');

    const { error } = await supabase.auth.signInWithPassword({
      email: email,
      password: password
    });
    
    if (error) {
      setMessage('Error: ' + error.message);
    } else {
      window.location.href = '/seller/dashboard';
    }
    setLoading(false);
  };

  return (
    <main className="min-h-screen bg-zambezi-dark text-zambezi-text p-4">
      <div className="max-w-md mx-auto pt-12">
        <div className="text-center mb-8">
          <h1 className="font-heading font-bold text-3xl mb-2">
            {mode === 'signup' ? 'Create Your Store' : 'Seller Login'}
          </h1>
          <p className="text-zambezi-text/70">
            {mode === 'signup' ? 'First month free. Sell without holding stock.' : 'Welcome back'}
          </p>
        </div>

        <div className="bg-black/20 border border-zambezi-teal/20 rounded-xl p-6">
          <div className="flex gap-2 mb-6">
            <button 
              onClick={() => { setMode('signup'); setAwaitingOtp(false); setMessage(''); setPassword(''); setConfirmPassword(''); }}
              className={`flex-1 py-2 rounded-lg font-medium ${mode === 'signup' ? 'bg-zambezi-orange text-white' : 'bg-zambezi-dark text-zambezi-text/70'}`}
            >
              Sign Up
            </button>
            <button 
              onClick={() => { setMode('signin'); setAwaitingOtp(false); setMessage(''); setPassword(''); }}
              className={`flex-1 py-2 rounded-lg font-medium ${mode === 'signin' ? 'bg-zambezi-orange text-white' : 'bg-zambezi-dark text-zambezi-text/70'}`}
            >
              Sign In
            </button>
          </div>

          <div className="space-y-4">
            <div>
              <label className="block text-sm font-medium mb-2">Email Address</label>
              <input 
                type="email" 
                value={email}
                onChange={(e) => setEmail(e.target.value)}
                placeholder="you@email.com"
                disabled={awaitingOtp}
                className="w-full bg-zambezi-dark border border-zambezi-teal/40 rounded-lg px-4 py-3 text-white placeholder-zambezi-text/50 disabled:opacity-50"
              />
            </div>

            <div>
              <label className="block text-sm font-medium mb-2">Password</label>
              <div className="relative">
                <input 
                  type={showPassword ? 'text' : 'password'}
                  value={password}
                  onChange={(e) => setPassword(e.target.value)}
                  placeholder={mode === 'signup' ? 'Min 6 characters' : 'Your password'}
                  disabled={awaitingOtp}
                  className="w-full bg-zambezi-dark border border-zambezi-teal/40 rounded-lg px-4 py-3 pr-12 text-white placeholder-zambezi-text/50 disabled:opacity-50"
                />
                <button
                  type="button"
                  onClick={() => setShowPassword(!showPassword)}
                  className="absolute right-3 top-1/2 -translate-y-1/2 text-zambezi-text/60 text-sm"
                >
                  {showPassword ? 'Hide' : 'Show'}
                </button>
              </div>
            </div>

            {mode === 'signup' && !awaitingOtp && (
              <div>
                <label className="block text-sm font-medium mb-2">Confirm Password</label>
                <input 
                  type={showPassword ? 'text' : 'password'}
                  value={confirmPassword}
                  onChange={(e) => setConfirmPassword(e.target.value)}
                  placeholder="Re-enter password"
                  className="w-full bg-zambezi-dark border border-zambezi-teal/40 rounded-lg px-4 py-3 text-white placeholder-zambezi-text/50"
                />
              </div>
            )}

            {mode === 'signup' && !awaitingOtp && (
              <>
                <div>
                  <label className="block text-sm font-medium mb-2">Store Name</label>
                  <input 
                    type="text" 
                    value={storeName}
                    onChange={(e) => setStoreName(e.target.value)}
                    placeholder="e.g. Ncube"
                    className="w-full bg-zambezi-dark border border-zambezi-teal/40 rounded-lg px-4 py-3 text-white placeholder-zambezi-text/50"
                  />
                </div>

                <div>
                  <label className="block text-sm font-medium mb-2">EcoCash Number</label>
                  <input 
                    type="tel" 
                    value={ecocashNumber}
                    onChange={(e) => setEcocashNumber(e.target.value)}
                    placeholder="077 123 4567"
                    className="w-full bg-zambezi-dark border border-zambezi-orange/60 rounded-lg px-4 py-3 text-white placeholder-zambezi-text/50"
                  />
                  <p className="text-xs text-zambezi-text/60 mt-1">For payouts when you make sales.</p>
                </div>

                <div>
                  <label className="block text-sm font-medium mb-2">Your City</label>
                  <select 
                    value={city}
                    onChange={(e) => setCity(e.target.value)}
                    className="w-full bg-zambezi-dark border border-zambezi-teal/40 rounded-lg px-4 py-3 text-white"
                  >
                    <option>Bulawayo</option>
                    <option>Harare</option>
                    <option>Gweru</option>
                    <option>Mutare</option>
                    <option>South Africa</option>
                    <option>Zambia</option>
                  </select>
                </div>
              </>
            )}

            {mode === 'signup' && awaitingOtp && (
              <div>
                <label className="block text-sm font-medium mb-2">Verification Code</label>
                <input 
                  type="text" 
                  value={otp}
                  onChange={(e) => setOtp(e.target.value)}
                  placeholder="Enter 6-digit code from email"
                  maxLength={6}
                  className="w-full bg-zambezi-dark border border-zambezi-orange/60 rounded-lg px-4 py-3 text-white text-center text-2xl tracking-widest placeholder-zambezi-text/50"
                />
                <p className="text-xs text-zambezi-text/60 mt-1">Check {email} for your code</p>
              </div>
            )}

            {!awaitingOtp ? (
              <button 
                onClick={mode === 'signup' ? handleSignUp : handleSignIn}
                disabled={loading}
                className="w-full bg-zambezi-orange hover:bg-zambezi-orange/90 disabled:bg-zinc-700 text-white font-bold py-4 rounded-lg"
              >
                {loading ? 'Processing...' : mode === 'signup' ? 'Create Store + Send Code' : 'Sign In'}
              </button>
            ) : (
              <button 
                onClick={handleVerifyOtp}
                disabled={loading || otp.length !== 6}
                className="w-full bg-zambezi-orange hover:bg-zambezi-orange/90 disabled:bg-zinc-700 text-white font-bold py-4 rounded-lg"
              >
                {loading ? 'Verifying...' : 'Verify & Enter Store'}
              </button>
            )}

            {message && (
              <div className="text-sm text-center p-3 rounded-lg bg-zambezi-teal/20 text-zambezi-teal">
                {message}
              </div>
            )}
          </div>

          {mode === 'signup' && !awaitingOtp && (
            <div className="mt-6 text-xs text-zambezi-text/60 text-center space-y-1">
              <p className="text-zambezi-orange font-medium">First month free for new sellers</p>
              <p>Then: $5/mo up to 20 products • $10/mo up to 50 • $20/mo unlimited</p>
              <p>You set prices above supplier recommended price. You keep the markup.</p>
            </div>
          )}
        </div>
      </div>
    </main>
  );
}
